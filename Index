<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>⭐ Kid Tag MX Niño - Panel Vendedor</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --sky: #4FC3F7;
    --blue: #1976D2;
    --sunny: #FFD600;
    --coral: #FF5252;
    --mint: #69F0AE;
    --dark: #0D1B2A;
    --mid: #37547A;
    --light: #E8F4FD;
    --shadow: rgba(13,27,42,0.13);
  }
  body {
    background: #EAF4FB;
    font-family: 'Nunito', sans-serif;
    min-height: 100vh;
    max-width: 420px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  /* ===== PANEL EDITOR ===== */
  .editor-panel {
    background: #0D1B2A;
    color: white;
    padding: 20px 18px;
  }
  .editor-panel h2 {
    font-size: 14px;
    letter-spacing: 2px;
    color: var(--sunny);
    margin-bottom: 16px;
    text-transform: uppercase;
    font-family: 'Fredoka One', cursive;
  }
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 12px;
  }
  .field-group label {
    font-size: 11px;
    color: var(--sky);
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .field-group input,
  .field-group select,
  .field-group textarea {
    background: #1A2D42;
    border: 1.5px solid #2A4A6A;
    color: white;
    font-family: 'Nunito', sans-serif;
    font-size: 14px;
    padding: 10px 14px;
    border-radius: 10px;
    width: 100%;
    outline: none;
  }
  .field-group select option { background: #0D1B2A; }
  .field-group textarea { resize: none; height: 70px; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .toggle-editor {
    background: #1A2D42;
    color: var(--sunny);
    font-family: 'Nunito', sans-serif;
    font-size: 12px;
    font-weight: 900;
    padding: 10px;
    border-radius: 10px;
    border: 1.5px solid #2A4A6A;
    width: 100%;
    cursor: pointer;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  .editor-content.hidden { display: none; }
  .checkbox-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .checkbox-row input[type="checkbox"] {
    width: 18px; height: 18px;
    accent-color: var(--sky);
  }
  .checkbox-row label { font-size: 13px; color: white; font-weight: 600; }
  .foto-upload-area {
    border: 2px dashed #2A4A6A;
    border-radius: 14px;
    padding: 16px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s;
    margin-bottom: 12px;
  }
  .foto-upload-area:hover { border-color: var(--sky); }
  .foto-upload-area input[type="file"] { display: none; }
  .foto-preview-wrap { display: flex; align-items: center; gap: 12px; margin-top: 10px; }
  .foto-preview {
    width: 60px; height: 60px;
    border-radius: 12px;
    object-fit: cover;
    display: none;
    border: 2px solid var(--sky);
  }
  .foto-status { font-size: 12px; color: var(--sky); font-weight: 700; }
  .btn-quitar-foto {
    background: #2A4A6A; color: var(--sky);
    font-family: 'Nunito', sans-serif;
    font-size: 11px; font-weight: 700;
    padding: 6px 12px; border-radius: 8px;
    border: none; cursor: pointer; display: none;
  }
  .seccion-titulo {
    font-size: 12px; color: var(--sunny);
    font-weight: 900; letter-spacing: 1.5px;
    text-transform: uppercase;
    margin: 16px 0 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #1A2D42;
    font-family: 'Fredoka One', cursive;
  }
  .btn-actualizar {
    background: #1A2D42;
    color: var(--sky);
    font-family: 'Nunito', sans-serif;
    font-size: 15px; font-weight: 900;
    padding: 14px; border-radius: 14px;
    border: 1.5px solid #2A4A6A;
    width: 100%; cursor: pointer;
    letter-spacing: 1px;
    transition: transform 0.15s;
    margin-top: 4px;
  }
  .btn-actualizar:active { transform: scale(0.97); }

  .btn-exportar {
    background: linear-gradient(135deg, #1976D2, #4FC3F7);
    color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 16px; font-weight: 900;
    padding: 18px; border-radius: 16px;
    border: none; width: 100%; cursor: pointer;
    letter-spacing: 1px;
    box-shadow: 0 6px 20px rgba(79,195,247,0.4);
    transition: transform 0.15s, box-shadow 0.15s;
    margin-top: 10px;
  }
  .btn-exportar:active {
    transform: scale(0.97);
    box-shadow: 0 3px 10px rgba(79,195,247,0.3);
  }
  .export-nota {
    font-size: 11px;
    color: #5A8AAA;
    text-align: center;
    margin-top: 8px;
    line-height: 1.5;
  }

  /* ===== VISTA PREVIA ===== */
  .preview-label {
    background: #071320;
    color: var(--sky);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 2px;
    text-align: center;
    padding: 8px;
    text-transform: uppercase;
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(160deg, #1565C0 0%, #1976D2 40%, #42A5F5 80%, #4FC3F7 100%);
    padding: 0 0 70px 0;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '⭐';
    position: absolute;
    font-size: 200px;
    opacity: 0.07;
    top: -30px; right: -40px;
    transform: rotate(-20deg);
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40px;
    background: #EAF4FB;
    border-radius: 40px 40px 0 0;
  }
  .hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 0;
  }
  .tag-logo {
    font-family: 'Fredoka One', cursive;
    font-size: 15px;
    color: rgba(255,255,255,0.9);
    letter-spacing: 1px;
  }
  .hero-badge {
    background: var(--sunny);
    color: #0D1B2A;
    font-size: 10px;
    font-weight: 900;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 1px;
  }
  .avatar-wrap {
    display: flex; flex-direction: column;
    align-items: center; padding-top: 24px; gap: 14px;
    position: relative; z-index: 1;
  }
  .avatar-card {
    width: 150px; height: 150px;
    border-radius: 50%;
    background: white; padding: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25), 0 0 0 4px rgba(255,214,0,0.6);
    animation: flotar 3s ease-in-out infinite;
    display: flex; align-items: center; justify-content: center;
  }
  @keyframes flotar {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-7px) rotate(1deg); }
  }
  .avatar-svg { width: 128px; height: 128px; border-radius: 50%; }
  .avatar-foto { width: 138px; height: 138px; border-radius: 50%; object-fit: cover; display: none; }
  .kid-name {
    font-family: 'Fredoka One', cursive;
    font-size: 42px;
    color: white;
    text-shadow: 0 3px 14px rgba(0,0,0,0.2);
    line-height: 1;
    letter-spacing: 1px;
  }
  .kid-sub {
    font-size: 14px;
    color: rgba(255,255,255,0.92);
    font-weight: 700;
    letter-spacing: 1px;
    margin-top: -6px;
  }

  /* MENSAJE PRINCIPAL */
  .mensaje-hero {
    background: var(--sunny);
    border-radius: 16px;
    padding: 12px 18px;
    margin: 0 18px;
    text-align: center;
    font-size: 14px;
    font-weight: 900;
    color: #0D1B2A;
    line-height: 1.5;
    box-shadow: 0 4px 16px rgba(255,214,0,0.35);
    position: relative;
    z-index: 2;
    margin-top: -10px;
  }
  .mensaje-hero span { font-size: 18px; }

  /* ===== CONTENT ===== */
  .content { padding: 14px 18px 32px; display: flex; flex-direction: column; gap: 14px; }

  .card {
    background: white;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 4px 20px var(--shadow);
  }
  .card-title {
    font-family: 'Fredoka One', cursive;
    font-size: 14px; font-weight: 900; letter-spacing: 1px;
    color: var(--blue); text-transform: uppercase;
    margin-bottom: 14px; display: flex; align-items: center; gap: 6px;
  }
  .card-title::after { content: ''; flex: 1; height: 1.5px; background: #DDEEFF; }
  .info-row { display: flex; align-items: center; gap: 12px; padding: 8px 0; border-bottom: 1px solid #EAF4FB; }
  .info-row:last-child { border-bottom: none; }
  .info-icon {
    width: 38px; height: 38px; border-radius: 12px;
    background: #EAF4FB;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .info-label { font-size: 11px; color: #7A9EC0; font-weight: 700; letter-spacing: 0.5px; }
  .info-value { font-size: 15px; color: var(--dark); font-weight: 700; }

  /* BOTONES DE CONTACTO */
  .btn-whatsapp {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: #25D366; color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 17px;
    padding: 17px; border-radius: 16px; border: none; width: 100%;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,0.38);
    transition: transform 0.15s;
  }
  .btn-whatsapp:active { transform: scale(0.97); }
  .btn-llamar {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: var(--coral); color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 17px;
    padding: 17px; border-radius: 16px; border: none; width: 100%;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 16px rgba(255,82,82,0.35);
    transition: transform 0.15s; margin-top: 10px;
  }
  .btn-llamar2 {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: var(--blue); color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 17px;
    padding: 17px; border-radius: 16px; border: none; width: 100%;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 16px rgba(25,118,210,0.35);
    transition: transform 0.15s; margin-top: 10px;
  }
  .btn-llamar:active, .btn-llamar2:active { transform: scale(0.97); }

  /* CHIPS */
  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .chip { background: #EAF4FB; border: 1.5px solid #B3D9F5; color: var(--mid); font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 20px; }
  .chip.alert { background: #FFF0F0; border-color: #FFB8B8; color: #D93025; }
  .chip.ok { background: #F0FFF4; border-color: #A8E6BA; color: #1A7F37; }
  .chip.info { background: #FFF8E1; border-color: #FFE082; color: #E65100; }

  .nota-box {
    background: #EAF4FB;
    border-left: 4px solid var(--sky);
    border-radius: 0 12px 12px 0;
    padding: 12px 14px;
    font-size: 13px; color: var(--mid); font-weight: 600;
    margin-top: 10px; line-height: 1.5;
  }

  /* CONTACTO SECUNDARIO */
  .contacto2-label {
    text-align: center;
    font-size: 11px;
    color: #7A9EC0;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 4px 0 2px;
  }

  .footer {
    text-align: center;
    padding: 10px 0 28px;
    font-size: 11px;
    color: #7A9EC0;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .footer span { color: var(--blue); }
</style>
</head>
<body>

<!-- ===== PANEL EDITOR ===== -->
<div class="editor-panel">
  <h2>⭐ Kid Tag MX — Niño 💙</h2>
  <button class="toggle-editor" onclick="toggleEditor()">▼ MOSTRAR / OCULTAR CAMPOS</button>

  <div class="editor-content" id="editorContent">

    <div class="seccion-titulo">📸 Foto del niño/a</div>
    <div class="foto-upload-area" onclick="document.getElementById('inputFoto').click()">
      <div style="font-size:32px; margin-bottom:6px;">📷</div>
      <div style="font-size:13px; color:#4FC3F7; font-weight:700;">Toca aquí para subir foto</div>
      <div style="font-size:11px; color:#3A6A8A; margin-top:4px;">JPG o PNG · Máx 5MB</div>
      <input type="file" id="inputFoto" accept="image/*" onchange="cargarFoto(event)">
    </div>
    <div class="foto-preview-wrap">
      <img id="fotoPreview" class="foto-preview" src="" alt="preview">
      <div>
        <div class="foto-status" id="fotoStatus">Sin foto · usando ilustración</div>
        <button class="btn-quitar-foto" id="btnQuitarFoto" onclick="quitarFoto()">✕ Quitar foto</button>
      </div>
    </div>

    <div class="seccion-titulo">👦 Datos del niño/a</div>
    <div class="two-col">
      <div class="field-group">
        <label>Nombre del niño/a</label>
        <input type="text" id="kidName" value="Sofía" oninput="actualizar()">
      </div>
      <div class="field-group">
        <label>Edad</label>
        <input type="text" id="kidEdad" value="6 años" oninput="actualizar()">
      </div>
    </div>
    <div class="two-col">
      <div class="field-group">
        <label>Sexo</label>
        <select id="kidSexo" onchange="actualizar()">
          <option value="niño">Niño</option>
          <option value="niña">Niña</option>
        </select>
      </div>
      <div class="field-group">
        <label>Señas / descripción</label>
        <input type="text" id="kidSenas" value="Cabello chino, ojos cafés" oninput="actualizar()">
      </div>
    </div>
    <div class="two-col">
      <div class="field-group">
        <label>Escuela / Kinder</label>
        <input type="text" id="kidEscuela" value="Colegio Arcoíris" oninput="actualizar()">
      </div>
      <div class="field-group">
        <label>Colonia / Ciudad</label>
        <input type="text" id="kidColonia" value="Narvarte, CDMX" oninput="actualizar()">
      </div>
    </div>

    <div class="seccion-titulo">👨‍👩‍👧 Contacto principal (mamá o papá)</div>
    <div class="field-group">
      <label>Nombre del papá (contacto 1)</label>
      <input type="text" id="parent1Name" value="Papá Roberto" oninput="actualizar()">
    </div>
    <div class="field-group">
      <label>Teléfono papá (sin lada)</label>
      <input type="text" id="parent1Phone" value="5512345678" oninput="actualizar()">
    </div>

    <div class="seccion-titulo">📞 Contacto de emergencia (segundo)</div>
    <div class="field-group">
      <label>Nombre de la mamá (contacto 2)</label>
      <input type="text" id="parent2Name" value="Mamá Laura" oninput="actualizar()">
    </div>
    <div class="field-group">
      <label>Teléfono mamá (sin lada)</label>
      <input type="text" id="parent2Phone" value="5587654321" oninput="actualizar()">
    </div>

    <div class="seccion-titulo">🏥 Salud y cuidados</div>
    <div class="checkbox-row">
      <input type="checkbox" id="chkAlergia" onchange="actualizar()">
      <label for="chkAlergia">⚠️ Tiene alergias</label>
    </div>
    <div class="checkbox-row">
      <input type="checkbox" id="chkMedicamento" onchange="actualizar()">
      <label for="chkMedicamento">💊 Toma medicamento</label>
    </div>
    <div class="field-group" id="medicamentoField" style="display:none; margin-top:8px;">
      <label>¿Qué medicamento?</label>
      <input type="text" id="kidMedicamento" value="" oninput="actualizar()">
    </div>
    <div class="checkbox-row">
      <input type="checkbox" id="chkCondicion" onchange="actualizar()">
      <label for="chkCondicion">🩺 Condición especial</label>
    </div>
    <div class="field-group" id="condicionField" style="display:none; margin-top:8px;">
      <label>¿Qué condición?</label>
      <input type="text" id="kidCondicion" value="" oninput="actualizar()">
    </div>
    <div class="field-group" style="margin-top:12px;">
      <label>Mensaje al que lo encuentre</label>
      <textarea id="kidNota" oninput="actualizar()">Hola 👋 Soy [nombre]. Si me encontraste, por favor avísale a mis papás. ¡Gracias por ayudarme! ❤️</textarea>
    </div>

    <br>
    <button class="btn-actualizar" onclick="actualizar()">👁️ ACTUALIZAR VISTA PREVIA</button>
    <button class="btn-exportar" onclick="exportarHTML()">
      ⬇️ EXPORTAR PÁGINA LISTA PARA EL CLIENTE
    </button>
    <div class="export-nota">
      Descarga el index.html ya con todos los datos.<br>
      Súbelo a GitHub y listo. ¡El cliente nunca verá este panel!
    </div>
    <br><br>
  </div>
</div>

<!-- SEPARADOR -->
<div class="preview-label">👁️ Vista previa — así lo ve quien encuentre al niño</div>

<!-- ===== VISTA DEL CLIENTE ===== -->
<div class="hero">
  <div class="hero-top">
    <div class="tag-logo">⭐ KID TAG MX</div>
    <div class="hero-badge">¡AYÚDAME!</div>
  </div>
  <div class="avatar-wrap">
    <div class="avatar-card">
      <svg class="avatar-svg" id="kidSVG" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"></svg>
      <img id="kidFoto" class="avatar-foto" src="" alt="foto niño">
    </div>
    <div class="kid-name" id="displayName">Sofía</div>
    <div class="kid-sub" id="displaySub">Niña · 6 años</div>
  </div>
</div>

<!-- Mensaje principal fuera del hero -->
<div class="mensaje-hero" id="displayMensaje">
  <span>👋</span> Hola, me llamo <strong id="displayNombreMsg">Sofía</strong>.<br>
  ¡Por favor avísale a mis papás que me encontraste!
</div>

<div class="content">
  <!-- CONTACTO 1 -->
  <div class="card">
    <div class="card-title">🚨 Contactar a mis papás</div>
    <div class="info-row">
      <div class="info-icon">👤</div>
      <div>
        <div class="info-label">Contacto principal</div>
        <div class="info-value" id="displayParent1">Mamá Laura</div>
      </div>
    </div>
    <div class="info-row">
      <div class="info-icon">📍</div>
      <div>
        <div class="info-label">Colonia / Ciudad</div>
        <div class="info-value" id="displayColonia">Narvarte, CDMX</div>
      </div>
    </div>
    <br>
    <a class="btn-whatsapp" id="btnWhatsapp1" href="#" target="_blank">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp al contacto 1
    </a>
    <a class="btn-llamar" id="btnLlamar1" href="#">📞 Llamar al contacto 1</a>
  </div>

  <!-- CONTACTO 2 -->
  <div class="card">
    <div class="card-title">📞 Contacto de emergencia</div>
    <div class="info-row">
      <div class="info-icon">👤</div>
      <div>
        <div class="info-label">Segundo contacto</div>
        <div class="info-value" id="displayParent2">Papá Roberto</div>
      </div>
    </div>
